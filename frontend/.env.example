# RHCLOUD V1 frontend configuration. Copy to `.env.local` and fill in.
# All NEXT_PUBLIC_* values are inlined into the client bundle at build time.

# Base URL of the FastAPI backend (Railway).
NEXT_PUBLIC_API_BASE=http://localhost:8000

# HMAC credentials for contract-3 request signing (C2).
NEXT_PUBLIC_API_KEY=client-a
NEXT_PUBLIC_API_SECRET=replace-with-the-matching-secret

# Set to 1 to run the UI against an in-browser mock backend (no API needed).
NEXT_PUBLIC_USE_MOCK=0

# ---------------------------------------------------------------------------
# SECURITY (read before deploying publicly):
# NEXT_PUBLIC_API_SECRET is shipped to the browser. A public single-page app
# therefore cannot keep the HMAC secret confidential — anyone loading the page
# can read it and mint valid signatures. This is acceptable ONLY for a trusted /
# internal deployment (e.g. a private Cloudflare Pages access-gated site). For an
# untrusted audience, do NOT embed the secret: put a thin signing proxy in front
# of the backend (proxy holds the secret, browser calls the proxy with a session
# cookie), per §9.1's "V1.x 演进: 短时签名令牌". The backend contract is unchanged.
