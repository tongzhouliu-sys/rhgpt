# RHCLOUD V1 — BACKEND environment (set these in Railway → Variables).
# This file documents the variables; do NOT commit real secrets. The app reads
# process env directly (Railway injects them); it does not load a .env file.

# ── Auth (required) ─────────────────────────────────────────────────────────
# HMAC credentials. Either a comma-separated keystore:
RHCLOUD_API_KEYS=client-a:CHANGE_ME_32_HEX_SECRET
# ...or a single pair (RHCLOUD_API_KEYS wins if both are set):
# RHCLOUD_API_KEY=client-a
# RHCLOUD_API_SECRET=CHANGE_ME_32_HEX_SECRET
# Generate a secret with:  openssl rand -hex 16
# The frontend's NEXT_PUBLIC_API_KEY/SECRET must match one of these pairs.

# ── CORS (required) ─────────────────────────────────────────────────────────
# Exact origin of the deployed frontend (never "*"). Fill after Cloudflare Pages
# is up, then redeploy the backend.
FRONTEND_ORIGIN=https://your-frontend.pages.dev

# ── Provider API keys ───────────────────────────────────────────────────────
# Gemini (P0 baseline — needed for api_smoke.yaml and round1.yaml):
GEMINI_API_KEY=
# GOOGLE_API_KEY=                 # accepted as an alias for GEMINI_API_KEY
# GEMINI_MODEL=gemini-1.5-pro     # optional override
# Qwen (only if used):
# DASHSCOPE_API_KEY=
# QWEN_MODEL=qwen-plus            # optional override

# ── Web Providers ───────────────────────────────────────────────────────────
# Run Chromium headed under Xvfb in the container (harder to flag as a bot).
RHCLOUD_HEADLESS=0

# ── Limits / ops (optional; defaults shown) ─────────────────────────────────
MAX_CONCURRENT_JOBS=2
RATE_LIMIT_PER_MIN=30
ALERT_CONSECUTIVE_THRESHOLD=3
LOG_LEVEL=INFO
# Paths (override only if you remap the Volume):
# PROVIDERS_PATH=config/providers.yaml
# PROMPTS_DIR=prompts
# SESSIONS_ROOT=data/sessions
# Session retention for the cleanup job (days):
# SESSION_RETENTION_DAYS=14
